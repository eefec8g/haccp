# Database
DATABASE_URL="postgresql://haccp:haccp@localhost:5433/haccp?schema=public"

# NextAuth
# Generer un secret : openssl rand -base64 32
AUTH_SECRET="replace-me-with-openssl-rand-base64-32"
NEXTAUTH_SECRET="replace-me-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# Application
APP_BASE_URL="http://localhost:3000"

# Email (SMTP)
# Pour tester sans envoyer reellement : provisionner un compte Ethereal
# via `createTestAccount()` dans src/lib/services/emailService.ts, puis
# coller les credentials ci-dessous. Le mail ne sera pas remis, mais une
# URL de preview sera loggee en console.
# Pour Resend en prod : SMTP_HOST="smtp.resend.com" + SMTP_PASSWORD=<API key>
# (bascule auto sur l'API HTTP Resend, plus rapide qu'en SMTP serverless).
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="HACCP Maison Givre <noreply@maison-givre.fr>"

# Rate limiting (Upstash Redis)
# https://upstash.com -> Redis -> REST API
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# App
NODE_ENV="development"
