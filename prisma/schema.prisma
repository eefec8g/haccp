// HACCP Maison Givre - Schema Prisma
// Source de verite metier : docs/CCF.md

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== ENUMS =====

enum UserRole {
  SALARIE
  RESPONSABLE
  ADMIN
}

enum Creneau {
  MATIN
  MIDI
  SOIR
}

enum TypeEquipement {
  CONGELATEUR
  VITRINE
  CHAMBRE_FROIDE
  AUTRE
}

enum AlerteStatus {
  OUVERTE
  RESOLUE
  IGNOREE
}

enum AuditAction {
  CREATE
  UPDATE
  DISABLE
  ENABLE
  DELETE
  EXPORT
  PHOTO_UPLOAD
  PHOTO_DELETE
  SIGNATURE_CREATE
  EXPORT_REGISTRE_CONSOLIDE
}

enum AuditEntityType {
  BOUTIQUE
  EQUIPEMENT
  USER
  INVITATION
  EXPORT
  PHOTO
  SIGNATURE
}

// ===== MODELS =====

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      UserRole
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  boutiqueSalarieId String?
  boutiqueSalarie   Boutique? @relation("SalarieBoutique", fields: [boutiqueSalarieId], references: [id])

  boutiquesResponsable BoutiqueUser[]
  releves              Releve[]
  alertesResolues      Alerte[]         @relation("ResoluPar")
  invitations          UserInvitation[] @relation("UserInvitations")
  auditLogsPerformed   AuditLog[]       @relation("AuditPerformed")
  photosUploaded       Photo[]          @relation("PhotoUploadedBy")
  signatures           Signature[]      @relation("SignatureSignataire")

  @@index([email])
  @@index([role])
  @@index([boutiqueSalarieId])
}

model Boutique {
  id        String   @id @default(uuid())
  nom       String
  adresse   String?
  ville     String?
  actif     Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  equipements  Equipement[]
  salaries     User[]         @relation("SalarieBoutique")
  responsables BoutiqueUser[]
  releves      Releve[]
  signatures   Signature[]

  @@index([actif])
}

model BoutiqueUser {
  boutiqueId String
  userId     String
  createdAt  DateTime @default(now())

  boutique Boutique @relation(fields: [boutiqueId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([boutiqueId, userId])
  @@index([userId])
}

model Equipement {
  id        String         @id @default(uuid())
  nom       String
  type      TypeEquipement
  seuilMin  Float
  seuilMax  Float
  actif     Boolean        @default(true)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  boutiqueId String
  boutique   Boutique @relation(fields: [boutiqueId], references: [id])

  releves Releve[]

  @@index([boutiqueId, actif])
}

model Releve {
  id               String   @id @default(uuid())
  date             DateTime @db.Date
  creneau          Creneau
  temperature      Float
  commentaire      String?
  alerteHorsSeuils Boolean  @default(false)
  signature        String
  ip               String?
  annuleParId      String?  @unique
  motifAnnulation  String?
  createdAt        DateTime @default(now())

  equipementId String
  equipement   Equipement @relation(fields: [equipementId], references: [id])

  boutiqueId String
  boutique   Boutique @relation(fields: [boutiqueId], references: [id])

  userId String
  user   User   @relation(fields: [userId], references: [id])

  annulePar Releve? @relation("ReleveAnnulation", fields: [annuleParId], references: [id])
  annule    Releve? @relation("ReleveAnnulation")

  alertes Alerte[]

  // NOTE : la contrainte "1 releve actif par (equipement, date, creneau)" est implementee
  // via un partial unique index ajoute par migration SQL :
  //   CREATE UNIQUE INDEX releve_actif_unique ON "Releve" ("equipementId", "date", "creneau")
  //   WHERE "annuleParId" IS NULL;
  // (Prisma ne supporte pas les partial unique indexes en schema.prisma natif)

  @@index([date, equipementId])
  @@index([boutiqueId, date])
  @@index([userId, createdAt])
}

model Alerte {
  id                    String       @id @default(uuid())
  status                AlerteStatus @default(OUVERTE)
  commentaireResolution String?
  resoluAt              DateTime?
  createdAt             DateTime     @default(now())

  releveId String @unique
  releve   Releve @relation(fields: [releveId], references: [id])

  resoluParId String?
  resoluPar   User?   @relation("ResoluPar", fields: [resoluParId], references: [id])

  photos Photo[]

  @@index([status, createdAt])
}

// Photo justificative attachee a une Alerte (US-PHO-001).
// Stockage Vercel Blob : `storageKey` = pathname dans le blob store
// (`photos/<alerteId>/<timestamp>-<uuid>.<ext>`). `blobUrl` est l'URL
// publique retournee par `put()` (Vercel Blob) au moment de l'upload,
// persistee pour decoupler la lecture de toute variable d'environnement
// reconstruisant l'URL.
//
// Cascade delete sur Alerte volontaire : en cas de suppression
// theorique d'une alerte (jamais en pratique cote metier HACCP), les
// blobs orphelins seraient supprimes en cascade.
model Photo {
  id               String   @id @default(uuid())
  alerteId         String
  alerte           Alerte   @relation(fields: [alerteId], references: [id], onDelete: Cascade)
  storageKey       String   @unique
  blobUrl          String
  filename         String
  mimeType         String
  sizeBytes        Int
  uploadedByUserId String
  uploadedBy       User     @relation("PhotoUploadedBy", fields: [uploadedByUserId], references: [id])
  createdAt        DateTime @default(now())

  @@index([alerteId])
  @@index([uploadedByUserId])
}

// Signature manuscrite du registre journalier (Epic SIGNATURE).
// Granularite : 1 signature par (boutiqueId, dateISO). La premiere signature
// verrouille le registre du jour (re-signature interdite).
//
// Stockage Vercel Blob : `storageKey` = pathname canonique
// (`signatures/<boutiqueId>/<dateISO>/<timestamp>-<uuid>.png`), `blobUrl`
// est l'URL publique persistee par `put()` au moment de l'upload.
//
// Tracabilite immuable HACCP : aucun UPDATE/DELETE. `signataireRoleSnapshot`
// fige le role au moment de la signature (memes garanties que les audit
// logs : un changement de role posterieur ne reecrit pas l'historique).
//
// `ipAddress` et `userAgent` sont captes pour audit DDPP (preuve "qui a
// signe, depuis ou, avec quel navigateur"). Le `RESTRICT` sur `User`
// empeche la suppression "fantome" d'un signataire audite.
model Signature {
  id                     String   @id @default(cuid())
  boutiqueId             String
  boutique               Boutique @relation(fields: [boutiqueId], references: [id], onDelete: Restrict)
  dateISO                String
  signataireId           String
  signataire             User     @relation("SignatureSignataire", fields: [signataireId], references: [id], onDelete: Restrict)
  signataireRoleSnapshot UserRole
  storageKey             String   @unique
  blobUrl                String
  ipAddress              String?
  userAgent              String?
  signedAt               DateTime @default(now())
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  @@unique([boutiqueId, dateISO])
  @@index([signataireId])
}

model PasswordResetToken {
  id        String    @id @default(uuid())
  email     String
  token     String    @unique // hash SHA256 du token (jamais en clair)
  expiresAt DateTime
  usedAt    DateTime? // anti-replay : null = non utilise
  createdAt DateTime  @default(now())

  @@index([email])
  @@index([token])
  @@index([expiresAt])
}

// Invitation envoyee par un Admin pour creer un nouvel utilisateur.
// Le token reel est hash SHA256 (jamais stocke en clair). L'invitation
// est consommee a l'acceptation (User cree + usedAt renseigne).
model UserInvitation {
  id        String    @id @default(uuid())
  email     String
  // Nom saisi par l'admin a l'invitation. Persiste ici (et non sur
  // User) pour rester coherent meme si l'admin reinvite : User n'est
  // cree qu'a l'acceptation (cf. service.acceptInvitation).
  name      String?
  token     String    @unique // hash SHA256 du token (jamais en clair)
  role      UserRole // role assigne a l'acceptation
  expiresAt DateTime
  usedAt    DateTime? // anti-replay : null = non utilisee
  createdAt DateTime  @default(now())

  invitedById String
  invitedBy   User   @relation("UserInvitations", fields: [invitedById], references: [id])

  // Affectation enregistree au moment de l'invitation. Denormalisee
  // pour rester independante de mutations sur les boutiques entre
  // l'invitation et l'acceptation (resolution coherente).
  boutiqueSalarieId    String?
  boutiquesResponsable String[]

  @@index([email])
  @@index([token])
  @@index([expiresAt])
  @@index([invitedById])
}

// Journal d'audit immuable des actions admin sensibles (US-ADM-004).
// La table n'est jamais modifiee/supprimee apres ecriture : tracabilite
// HACCP. La cle etrangere `performedById` reste ON DELETE RESTRICT pour
// empecher la suppression "fantome" d'un acteur audite.
model AuditLog {
  id            String          @id @default(uuid())
  action        AuditAction
  entityType    AuditEntityType
  entityId      String
  entityLabel   String? // snapshot lisible (nom boutique, email user...)
  motif         String?         @db.Text
  metadata      Json?
  performedById String
  performedBy   User            @relation("AuditPerformed", fields: [performedById], references: [id])
  createdAt     DateTime        @default(now())

  @@index([entityType, entityId])
  @@index([performedById])
  @@index([createdAt])
}
